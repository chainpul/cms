---
// 1. Pindahkan prerender ke atas (opsional, tapi standar praktik yang baik)
export const prerender = true;

import { getCollection } from 'astro:content';
import MainLayout from '@layouts/MainLayout.astro';

// 2. Definisikan path statis
export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 3. Ambil data dari props
const { post } = Astro.props;
const { Content } = await post.render();

// Ambil data spesifik agar kode di bawah lebih bersih
const { title, summary, pubDate, heroImage, category } = post.data;
---

<MainLayout title={title} description={summary}>
  <article style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
    <header style="text-align: center; margin-bottom: 3rem; border-bottom: 1px solid #eee; padding-bottom: 2rem;">
      <p style="color: #990000; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem; margin-bottom: 0.5rem;">
        {category || 'News'}
      </p>
      
      <p style="color: #666; font-family: sans-serif; font-size: 0.9rem; margin-bottom: 1.5rem;">
        {new Date(pubDate).toLocaleDateString('id-ID', { dateStyle: 'full' })}
      </p>

      <h1 style="font-family: 'Playfair Display', serif; font-size: clamp(2rem, 8vw, 3.5rem); line-height: 1.1; margin: 0 auto; font-weight: 900;">
        {title}
      </h1>
    </header>

    {heroImage && (
      <figure style="margin: 0 0 2.5rem 0;">
        <img 
          src={heroImage} 
          alt={title} 
          style="width: 100%; height: auto; border: 1px solid #000; display: block;" 
        />
        {/* Opsional: Tambahkan caption jika ada di frontmatter nanti */}
      </figure>
    )}

    {/* Gunakan class CSS untuk konten agar styling Markdown-nya rapi */}
    <div class="article-content">
      <Content />
    </div>

    <footer style="margin-top: 5rem; padding-top: 2rem; border-top: 4px double #333; text-align: center;">
      <a href="/" style="color: #990000; text-decoration: none; font-weight: bold; font-family: sans-serif; font-size: 0.9rem; letter-spacing: 1px;">
        ← KEMBALI KE BERANDA
      </a>
    </footer>
  </article>
</MainLayout>

<style is:global>
  /* Styling khusus untuk isi konten dari Markdown */
  .article-content {
    font-family: 'Inter', sans-serif;
    font-size: 1.2rem;
    line-height: 1.8;
    color: #222;
    text-align: justify;
  }

  .article-content p {
    margin-bottom: 1.8rem;
  }

  .article-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e9decf;
  }

  .article-content img {
    max-width: 100%;
    height: auto;
    border: 1px solid #ccc;
    margin: 2rem 0;
  }

  .article-content blockquote {
    border-left: 4px solid #990000;
    margin-left: 0;
    padding-left: 1.5rem;
    font-style: italic;
    color: #555;
  }
</style>